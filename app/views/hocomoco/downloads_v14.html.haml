.row
  .col-md-1
  .col-md-8
    .pageheader Downloads (HOCOMOCO-14)
    .zenodo-data
      %b Data:
      %ul
        %li Complete release data is available at #{link_to 'Zenodo', 'https://zenodo.org/records/14883878'}.
        %li Harmonized list of human transcription factors and respective mouse orthologs based on the TFClass classification (Extended with Codebook TFs for v14): #{link_to 'tf_masterlist.tsv', hocomoco14_bundle_url('tf_masterlist.tsv')}.

    .tools
      %b Tools:
      %ul
        %li
          MoLoTool - #{link_to 'web interface', 'https://molotool.autosome.org'} for motif finding.
        %li
          SPRY-SARUS tool for motif finding (Java): #{link_to 'jar', 'https://raw.githubusercontent.com/autosome-ru/sarus/master/releases/sarus-2.1.0.jar'}, #{link_to 'readme', 'https://github.com/autosome-ru/sarus'}
        %li
          MACRO-APE tool for motif comparison, P-value and threshold estimation: #{link_to 'jar', 'https://raw.githubusercontent.com/autosome-ru/macro-perfectos-ape/master/releases/ape-3.0.6.jar'}, #{link_to 'manual', 'https://opera.autosome.org/downloads/MACRO-PERFECTOS-APE_manual.pdf'}, #{link_to 'website', ENV['MACROAPE_URL'] }
        %li
          PERFECTOS-APE tool for functional annotation of sequence variants overlappint TFBS: #{link_to 'jar', 'https://raw.githubusercontent.com/autosome-ru/macro-perfectos-ape/master/releases/ape-3.0.6.jar'}, #{link_to 'manual', 'https://opera.autosome.org/downloads/MACRO-PERFECTOS-APE_manual.pdf'}, #{link_to 'website', ENV['PERFECTOSAPE_URL']}
  .col-md-3
    .contacts
      %b Contacts
      %ul
        %li Technical questions and suggestions should be addressed to #{link_to 'Ilya Vorontsov', 'mailto:vorontsov.i.e/at/gmail/dot/com'} and #{link_to 'Ivan Kulakovskiy', 'mailto:ivan.kulakovskiy/at/gmail/dot/com'}.
        %li General questions should be addressed to #{link_to 'Ivan Kulakovskiy', 'mailto:ivan.kulakovskiy/at/gmail/dot/com'}, #{link_to 'Yulia Medvedeva', 'mailto:ju.medvedeva/at/gmail/dot/com'} or #{link_to 'Vsevolod Makeev', 'mailto:vsevolod.makeev/at/gmail/dot/com'}.

.row
  .col-md-1
  .col-md-7
    .cite
      %b Citation:
      .title
        = link_to 'https://doi.org/10.1093/nar/gkad1077' do
          HOCOMOCO in 2024: a rebuild of the curated collection of binding models for human and mouse transcription factors
      .authors
        Ilya E Vorontsov, Irina A Eliseeva, Arsenii Zinkevich, Mikhail Nikonov, Sergey Abramov, Alexandr Boytsov, Vasily Kamenets, Alexandra Kasianova, Semyon Kolmykov, Ivan S Yevshin, Alexander Favorov, Yulia A Medvedeva, Arttu Jolma, Fedor Kolpakov, Vsevolod J Makeev, Ivan V Kulakovskiy
      .journal Nucleic Acids Research, gkad1077 (16 November 2023)
      .doi doi: 10.1093/nar/gkad1077

    .license
      %b License:
      HOCOMOCO motif collection is distributed under #{link_to 'WTFPL', 'https://en.wikipedia.org/wiki/WTFPL'}.
      If you prefer more standard licenses, feel free to treat WTFPL as CC-BY.

.row
  .col-md-6
    %hr
      %h1.non_redundant_header Non-redundant motif subset

      %table.table-responsive-lg.downloads.download-non-redundant
        %thead
          %tr
            %th
            %th H14CORE-CLUSTERED
        %tbody
          %tr
            %th.row-hdr Number of motif clusters
            %td{class: 'H14CORE-CLUSTERED'}= MotifCluster.all.size
          %tr
            %th.row-hdr
              Clusters annotation
            %td{class: 'H14CORE-CLUSTERED'}= link_to 'cluster_list.tsv', hocomoco14_bundle_url('H14CORE-CLUSTERED/cluster_list.tsv')
          %tr
            %th.row-hdr Representative motifs annotation
            %td{class: 'H14CORE-CLUSTERED'}= link_to "H14CORE-CLUSTERED_annotation.jsonl", hocomoco14_bundle_url("H14CORE-CLUSTERED/H14CORE-CLUSTERED_annotation.jsonl")

          %tr
            %th.row-hdr
              PWM
              = help_icon(title: 'MACRO-PERFECTOS-APE compatible format')
            %td{class: 'H14CORE-CLUSTERED'}= link_to "H14CORE-CLUSTERED_pwm.tar.gz", hocomoco14_bundle_url("H14CORE-CLUSTERED/H14CORE-CLUSTERED_pwm.tar.gz")
          %tr
            %th.row-hdr
              PCM
              = help_icon(title: 'MACRO-PERFECTOS-APE compatible format')
            %td{class: 'H14CORE-CLUSTERED'}= link_to "H14CORE-CLUSTERED_pcm.tar.gz", hocomoco14_bundle_url("H14CORE-CLUSTERED/H14CORE-CLUSTERED_pcm.tar.gz")
          %tr
            %th.row-hdr
              PFM
              = help_icon(title: 'MACRO-PERFECTOS-APE compatible format')
            %td{class: 'H14CORE-CLUSTERED'}= link_to "H14CORE-CLUSTERED_pfm.tar.gz", hocomoco14_bundle_url("H14CORE-CLUSTERED/H14CORE-CLUSTERED_pfm.tar.gz")
          %tr
            %th.row-hdr
              Threshold to P-value map
              = help_icon(title: 'Precalculated thresholds to be utilized by PERFECTOS-APE (uniform nucleotide frequencies were used for P-value estimation)')
            %td{class: 'H14CORE-CLUSTERED'}= link_to 'H14CORE-CLUSTERED_thresholds.tar.gz', hocomoco14_bundle_url('H14CORE-CLUSTERED/H14CORE-CLUSTERED_thresholds.tar.gz')
          %tr
            %th.row-hdr
              Cluster logos
            %td{class: 'H14CORE-CLUSTERED'}= link_to 'H14CORE-CLUSTERED_cluster_logos.tar.gz', hocomoco14_bundle_url('H14CORE-CLUSTERED/H14CORE-CLUSTERED_cluster_logos.tar.gz')

.row
  .col-md-12
    %hr
    %h1.downloads_header HOCOMOCO v14 subcollections
    = render partial: 'download_table_v13_14', locals: {bundle_url: ->(path){ hocomoco14_bundle_url(path) }, collections: ['H14CORE', 'H14INVIVO', 'H14INVITRO', 'H14RSNP'], hocomoco_version: 'hocomoco14' }


- content_for(:title) do
  HOCOMOCO-v14 Downloads - HOmo sapiens COmprehensive MOdel COllection
- content_for(:meta_description) do
  Download HOCOMOCO TFBS motif collection and supplementary data.
/ - content_for(:canonical_url, "https://hocomoco14.autosome.org/downloads_v14")
